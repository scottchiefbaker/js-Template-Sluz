{
  "name": "template-sluz",
  "version": "0.9.3",
  "description": "A minimalistic JavaScript templating engine with Smarty-like syntax",
  "type": "module",
  "main": "./src/sluz.js",
  "exports": {
    ".": "./src/sluz.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "esbuild src/sluz.js --minify --format=esm --outfile=src/sluz.min.js"
  },
  "files": [
    "src"
  ],
  "keywords": [
    "template",
    "smarty",
    "templating",
    "sluz"
  ],
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "esbuild": "^0.28.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
